{:paths ["scripts" "test"
         "shared/skills/add-todo/src"
         "shared/skills/add-todo/test"
         "shared/skills/pk-tmux/src"
         "shared/skills/sandbox/src"
         "shared/skills/sandbox/test"]

 :deps {io.github.caseneuve/mux-bb
        {:git/url "https://github.com/caseneuve/mux-bb.git"
         :git/sha "117af6d76850346ef95ff696e18920338df37b54"}}

 :tasks
 {:init
  (do
    (require '[clojure.string :as str])
    (require '[clojure.java.shell :as jsh])
    (def end2edn-root (str (System/getenv "HOME") "/git/end2edn"))
    (def podman-args
      (str "podman run --rm "
           "--network none "
           "-v " (System/getProperty "user.dir") ":/work:ro "
           "-v " end2edn-root ":" end2edn-root ":ro "
           "--tmpfs /tmp:rw,mode=1777 "
           "--tmpfs /var/tmp:rw,mode=1777 "
           "-w /work "))
    (def base-image "docker.io/babashka/babashka")
    (def test-image "localhost/dotagents-test")
    (def podman-base (str podman-args base-image))
    (def podman-test (str podman-args test-image))
    (def unit-runner "bb -cp scripts:test:shared/skills/add-todo/src:shared/skills/add-todo/test:shared/skills/pk-tmux/src:shared/skills/sandbox/src:shared/skills/sandbox/test test/unit/runner.clj")
    (def e2e-runner (str "bb -cp scripts:test:" end2edn-root "/src test/e2e/runner.clj"))
    ;; ── Relay config ──
    ;; Matches the defaults baked into shared/relay/main.ts so ad-hoc
    ;; `bun shared/relay/main.ts` invocations and `bb relay:*` agree.
    (def relay-script "shared/relay/main.ts")
    (def relay-socket "/tmp/agent-channels.sock")
    (def relay-log "/tmp/agent-relay.log")
    (defn relay-pid []
      (let [r (jsh/sh "pgrep" "-f" relay-script)]
        (when (zero? (:exit r))
          (first (str/split-lines (str/trim (:out r))))))))

  build:test-image
  {:doc "Build the podman test image (with tmux)"
   :task (shell "podman build -t dotagents-test -f test/Containerfile .")}

  test
  {:doc "Run unit and E2E tests in isolated podman containers"
   :task (do
           (run 'test:unit)
           (println)
           (run 'test:e2e))}

  test:unit
  {:doc "Run pure unit tests in isolated podman container"
   :task (shell (str podman-test " " unit-runner))}

  test:e2e
  {:doc "Run end2edn E2E tests in isolated podman container"
   :task (shell (str podman-test " " e2e-runner
                     (when (seq *command-line-args*)
                       (str " " (str/join " " *command-line-args*)))))}

  bootstrap
  {:doc "Run bootstrap script with forwarded args"
   :task (apply shell "bb" "-m" "bootstrap" *command-line-args*)}

  boot
  {:doc "Alias for bootstrap"
   :task (run 'bootstrap)}

  test:ci
  {:doc "Run tests directly (CI only)"
   :task (do
           (when-not (System/getenv "CI")
             (println "Error: test:ci can only run in CI environments")
             (println "Use 'bb test' locally to run in isolated podman")
             (System/exit 1))
           (shell unit-runner)
           (println)
           (shell (str e2e-runner
                       (when (seq *command-line-args*)
                         (str " " (str/join " " *command-line-args*))))))}

  ;; ── Relay management ──
  ;; Manage the agent-channel relay process (bun shared/relay/main.ts).
  ;; The relay is a long-running per-user daemon; these tasks replace the
  ;; 9-days-ago hand-started shell process so restarts (e.g. to pick up
  ;; server.ts fixes) are reproducible.

  relay:status
  {:doc "Show relay process status (PID, uptime, socket, log tail)"
   :task (let [pid (relay-pid)]
           (if pid
             (do
               (println "relay pid:" pid)
               (shell "ps" "-o" "pid,etime,rss,command" "-p" pid)
               (println)
               (shell "ls" "-la" relay-socket)
               (println)
               (println "--- last 10 log lines (" relay-log ") ---")
               (shell {:continue true} "tail" "-n" "10" relay-log))
             (println "relay: not running")))}

  relay:start
  {:doc "Start the relay detached; logs to /tmp/agent-relay.log"
   :task (if-let [pid (relay-pid)]
           (println "relay already running, pid:" pid)
           (do
             (shell "sh" "-c"
                    (str "nohup bun " relay-script
                         " --quiet > " relay-log " 2>&1 &"))
             ;; Give bun a moment to fork + bind the socket before we
             ;; report the PID.
             (Thread/sleep 400)
             (if-let [pid (relay-pid)]
               (println "relay started, pid:" pid)
               (do (println "relay start: PID not detected; check" relay-log)
                   (System/exit 1)))))}

  relay:stop
  {:doc "Stop the running relay (SIGTERM, clean shutdown)"
   :task (if-let [pid (relay-pid)]
           (do (shell "kill" pid)
               ;; Wait for the SIGTERM handler in main.ts to unlink the
               ;; socket and exit before returning.
               (Thread/sleep 500)
               (if (relay-pid)
                 (do (println "relay still running after SIGTERM; sending SIGKILL")
                     (shell "kill" "-9" pid))
                 (println "relay stopped, pid was:" pid)))
           (println "relay: not running"))}

  relay:restart
  {:doc "Restart the relay (stop + short pause + start)"
   :task (do (run 'relay:stop)
             (Thread/sleep 700)
             (run 'relay:start))}

  relay:logs
  {:doc "Tail the relay log (Ctrl+C to stop)"
   :task (shell "tail" "-f" relay-log)}}}
