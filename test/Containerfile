FROM docker.io/babashka/babashka
RUN apt-get update -qq && apt-get install -y -qq --no-install-recommends \
      tmux git default-jdk-headless \
    && rm -rf /var/lib/apt/lists/*
# Pin dep cache locations so tests that override HOME still find them
ENV DEPS_CLJ_TOOLS_DIR=/root/.deps.clj
ENV GITLIBS=/root/.gitlibs
# Pre-resolve git deps so E2E runs work with --network none
COPY bb.edn /work/bb.edn
RUN cd /work && bb -e nil
