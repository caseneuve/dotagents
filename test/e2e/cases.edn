[{:suite :bootstrap
  :desc "Bootstrap behavior through bb tasks in isolated temp homes"
  :cases
  [{:scenario :pi-installs-only-extensions-and-themes
    :given {:fixtures [[:remove "/tmp/dotagents-e2e-pi"]
                       [:dir "/tmp/dotagents-e2e-pi/home"]]}
    :cleanup {:fixtures [[:remove "/tmp/dotagents-e2e-pi"]]}
    :when {:cwd "/work"
           :env {"HOME" "/tmp/dotagents-e2e-pi/home"}
           :run ["bb" "bootstrap" "pi"]}
    :then [[:exit-code 0]
           [:stdout-contains "== Pi =="]
           [:fs-layout {:symlinks [["/tmp/dotagents-e2e-pi/home/.pi/agent/extensions/bookmark.ts" "/work/pi/extensions/bookmark.ts"]
                                   ["/tmp/dotagents-e2e-pi/home/.pi/agent/extensions/branch-status.ts" "/work/pi/extensions/branch-status.ts"]
                                   ["/tmp/dotagents-e2e-pi/home/.pi/agent/themes/modus-operandi.json" "/work/pi/themes/modus-operandi.json"]]
                        :missing ["/tmp/dotagents-e2e-pi/home/.pi/agent/settings.json"
                                  "/tmp/dotagents-e2e-pi/home/.pi/agent/justfile"]}]]}

   {:scenario :agents-copies-docs-and-links-helpers
    :given {:fixtures [[:remove "/tmp/dotagents-e2e-agents"]
                       [:dir "/tmp/dotagents-e2e-agents/home"]]}
    :cleanup {:fixtures [[:remove "/tmp/dotagents-e2e-agents"]]}
    :when {:cwd "/work"
           :env {"HOME" "/tmp/dotagents-e2e-agents/home"}
           :run ["bb" "bootstrap" "agents"]}
    :then [[:exit-code 0]
           [:stdout-contains "== Agents =="]
           [:fs-layout {:symlinks [["/tmp/dotagents-e2e-agents/home/.agents/AGENTS.md" "/work/agents/AGENTS.md"]
                                   ["/tmp/dotagents-e2e-agents/home/.codex/AGENTS.md" "/work/agents/AGENTS.md"]
                                   ["/tmp/dotagents-e2e-agents/home/.agents/skills/add-todo/todo-new.sh" "/work/shared/skills/add-todo/todo-new.sh"]]
                        :regular-files ["/tmp/dotagents-e2e-agents/home/.agents/skills/add-todo/SKILL.md"]}]]}

   {:scenario :claude-merges-settings
    :given {:fixtures [[:remove "/tmp/dotagents-e2e-claude"]
                       [:dir "/tmp/dotagents-e2e-claude/home/.claude"]
                       [:copy "test/fixtures/claude-settings.json" "/tmp/dotagents-e2e-claude/home/.claude/settings.json"]]}
    :cleanup {:fixtures [[:remove "/tmp/dotagents-e2e-claude"]]}
    :when {:cwd "/work"
           :env {"HOME" "/tmp/dotagents-e2e-claude/home"}
           :run ["bb" "bootstrap" "claude"]}
    :then [[:exit-code 0]
           [:stdout-contains "== Claude =="]
           [:fs-layout {:json-equals [["/tmp/dotagents-e2e-claude/home/.claude/settings.json" [:model] "keep-me"]
                                      ["/tmp/dotagents-e2e-claude/home/.claude/settings.json" [:custom] {:nested true}]
                                      ["/tmp/dotagents-e2e-claude/home/.claude/settings.json"
                                       [:hooks :PostToolUse 0 :hooks 0 :command]
                                       "/tmp/dotagents-e2e-claude/home/.claude/hooks/smart-lint.sh"]]
                        :json-contains [["/tmp/dotagents-e2e-claude/home/.claude/settings.json"
                                         [:permissions :allow]
                                         "Bash(/tmp/existing:*)"]
                                        ["/tmp/dotagents-e2e-claude/home/.claude/settings.json"
                                         [:permissions :allow]
                                         "Bash(/tmp/dotagents-e2e-claude/home/.claude/skills/pk-tmux/tmux-status.sh:*)"]]}]]}

   {:scenario :dry-run-makes-no-changes
    :given {:fixtures [[:remove "/tmp/dotagents-e2e-dry"]
                       [:dir "/tmp/dotagents-e2e-dry/home"]]}
    :cleanup {:fixtures [[:remove "/tmp/dotagents-e2e-dry"]]}
    :when {:cwd "/work"
           :env {"HOME" "/tmp/dotagents-e2e-dry/home"}
           :run ["bb" "bootstrap" "all" "--dry-run"]}
    :then [[:exit-code 0]
           [:stdout-contains "Dry run: enabled"]
           [:stdout-contains "Would merge Claude settings"]
           [:fs-layout {:missing ["/tmp/dotagents-e2e-dry/home/.claude"
                                  "/tmp/dotagents-e2e-dry/home/.agents"
                                  "/tmp/dotagents-e2e-dry/home/.pi"]}]]}]}]
