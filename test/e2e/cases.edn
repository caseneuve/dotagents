[{:suite :bootstrap
  :desc "Bootstrap behavior through bb tasks in isolated temp homes"
  :tests
  [{:test :pi-installs-only-extensions-and-themes
    :cwd "/work"
    :env {"HOME" "/tmp/dotagents-e2e-pi/home"}
    :setup-cmd [["rm" "-rf" "/tmp/dotagents-e2e-pi"]
                ["mkdir" "-p" "/tmp/dotagents-e2e-pi/home"]]
    :cmd ["bb" "bootstrap" "pi"]
    :teardown-cmd ["rm" "-rf" "/tmp/dotagents-e2e-pi"]
    :expect [[:exit-code 0]
             [:stdout-contains "== Pi =="]
             [:home-layout "/tmp/dotagents-e2e-pi/home"
              {:symlinks [["/.pi/agent/extensions/bookmark.ts" "/work/pi/extensions/bookmark.ts"]
                          ["/.pi/agent/extensions/branch-status.ts" "/work/pi/extensions/branch-status.ts"]
                          ["/.pi/agent/themes/modus-operandi.json" "/work/pi/themes/modus-operandi.json"]]
               :missing ["/.pi/agent/settings.json"
                         "/.pi/agent/justfile"]}]]}

   {:test :agents-copies-docs-and-links-helpers
    :cwd "/work"
    :env {"HOME" "/tmp/dotagents-e2e-agents/home"}
    :setup-cmd [["rm" "-rf" "/tmp/dotagents-e2e-agents"]
                ["mkdir" "-p" "/tmp/dotagents-e2e-agents/home"]]
    :cmd ["bb" "bootstrap" "agents"]
    :teardown-cmd ["rm" "-rf" "/tmp/dotagents-e2e-agents"]
    :expect [[:exit-code 0]
             [:stdout-contains "== Agents =="]
             [:home-layout "/tmp/dotagents-e2e-agents/home"
              {:symlinks [["/.agents/AGENTS.md" "/work/agents/AGENTS.md"]
                          ["/.codex/AGENTS.md" "/work/agents/AGENTS.md"]
                          ["/.agents/skills/add-todo/todo-new.sh" "/work/shared/skills/add-todo/todo-new.sh"]]
               :regular-files ["/.agents/skills/add-todo/SKILL.md"]}]]}

   {:test :claude-merges-settings
    :cwd "/work"
    :env {"HOME" "/tmp/dotagents-e2e-claude/home"}
    :setup-cmd [["rm" "-rf" "/tmp/dotagents-e2e-claude"]
                ["mkdir" "-p" "/tmp/dotagents-e2e-claude/home/.claude"]
                ["cp" "test/fixtures/claude-settings.json" "/tmp/dotagents-e2e-claude/home/.claude/settings.json"]]
    :cmd ["bb" "bootstrap" "claude"]
    :teardown-cmd ["rm" "-rf" "/tmp/dotagents-e2e-claude"]
    :expect [[:exit-code 0]
             [:stdout-contains "== Claude =="]
             [:home-layout "/tmp/dotagents-e2e-claude/home"
              {:json-equals [["/.claude/settings.json" [:model] "keep-me"]
                             ["/.claude/settings.json" [:custom] {:nested true}]
                             ["/.claude/settings.json"
                              [:hooks :PostToolUse 0 :hooks 0 :command]
                              "/tmp/dotagents-e2e-claude/home/.claude/hooks/smart-lint.sh"]]
               :json-contains [["/.claude/settings.json"
                                [:permissions :allow]
                                "Bash(/tmp/existing:*)"]
                               ["/.claude/settings.json"
                                [:permissions :allow]
                                "Bash(/tmp/dotagents-e2e-claude/home/.claude/skills/pk-tmux/tmux-status.sh:*)"]]}]]}

   {:test :dry-run-makes-no-changes
    :cwd "/work"
    :env {"HOME" "/tmp/dotagents-e2e-dry/home"}
    :setup-cmd [["rm" "-rf" "/tmp/dotagents-e2e-dry"]
                ["mkdir" "-p" "/tmp/dotagents-e2e-dry/home"]]
    :cmd ["bb" "bootstrap" "all" "--dry-run"]
    :teardown-cmd ["rm" "-rf" "/tmp/dotagents-e2e-dry"]
    :expect [[:exit-code 0]
             [:stdout-contains "Dry run: enabled"]
             [:stdout-contains "Would merge Claude settings"]
             [:home-layout "/tmp/dotagents-e2e-dry/home"
              {:missing ["/.claude"
                         "/.agents"
                         "/.pi"]}]]}]}]
