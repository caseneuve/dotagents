[{:suite :bootstrap
  :desc "Bootstrap behavior through bb tasks in isolated temp homes"
  :given {:vars {:work "/work"
                  :fixtures-dir "test/fixtures"}}
  :cases
  [{:scenario :pi-writes-settings-for-extensions-themes-and-theme-name
    :given {:vars {:root "/tmp/dotagents-e2e-pi"
                   :home "/tmp/dotagents-e2e-pi/home"}
             :fixtures [[:remove "{root}"]
                        [:dir "{home}"]]}
    :cleanup {:fixtures [[:remove "{root}"]]}
    :when {:cwd "{work}"
           :env {"HOME" "{home}"}
           :run ["bb" "bootstrap" "pi"]}
    :then [[:exit-code 0]
           [:stdout-contains "== Pi =="]
           [:stdout-contains "Merging Pi settings"]
           [:fs-layout {:json-equals [["{home}/.pi/agent/settings.json" [:theme] "modus-operandi"]
                                      ["{home}/.pi/agent/settings.json" [:extensions] ["{work}/pi/extensions"]]
                                      ["{home}/.pi/agent/settings.json" [:themes] ["{work}/pi/themes"]]]
                        :missing ["{home}/.pi/agent/extensions"
                                  "{home}/.pi/agent/themes"
                                  "{home}/.pi/agent/justfile"]}]]}

   {:scenario :agents-copies-docs-and-links-helpers
    :given {:vars {:root "/tmp/dotagents-e2e-agents"
                   :home "/tmp/dotagents-e2e-agents/home"}
             :fixtures [[:remove "{root}"]
                        [:dir "{home}"]]}
    :cleanup {:fixtures [[:remove "{root}"]]}
    :when {:cwd "{work}"
           :env {"HOME" "{home}"}
           :run ["bb" "bootstrap" "agents"]}
    :then [[:exit-code 0]
           [:stdout-contains "== Agents =="]
           [:fs-layout {:symlinks [["{home}/.agents/AGENTS.md" "{work}/agents/AGENTS.md"]
                                   ["{home}/.codex/AGENTS.md" "{work}/agents/AGENTS.md"]
                                   ["{home}/.agents/skills/add-todo/todo-new.sh" "{work}/shared/skills/add-todo/todo-new.sh"]]
                        :regular-files ["{home}/.agents/skills/add-todo/SKILL.md"]}]]}

   {:scenario :claude-merges-settings
    :given {:vars {:root "/tmp/dotagents-e2e-claude"
                   :home "/tmp/dotagents-e2e-claude/home"}
             :fixtures [[:remove "{root}"]
                        [:dir "{home}/.claude"]
                        [:copy "{fixtures-dir}/claude-settings.json" "{home}/.claude/settings.json"]]}
    :cleanup {:fixtures [[:remove "{root}"]]}
    :when {:cwd "{work}"
           :env {"HOME" "{home}"}
           :run ["bb" "bootstrap" "claude"]}
    :then [[:exit-code 0]
           [:stdout-contains "== Claude =="]
           [:fs-layout {:json-equals [["{home}/.claude/settings.json" [:model] "keep-me"]
                                      ["{home}/.claude/settings.json" [:custom] {:nested true}]
                                      ["{home}/.claude/settings.json"
                                       [:hooks :PostToolUse 0 :hooks 0 :command]
                                       "{home}/.claude/hooks/smart-lint.sh"]]
                        :json-contains [["{home}/.claude/settings.json"
                                         [:permissions :allow]
                                         "Bash(/tmp/existing:*)"]
                                        ["{home}/.claude/settings.json"
                                         [:permissions :allow]
                                         "Bash({home}/.claude/skills/pk-tmux/tmux-status.sh:*)"]]}]]}

   {:scenario :dry-run-makes-no-changes
    :given {:vars {:root "/tmp/dotagents-e2e-dry"
                   :home "/tmp/dotagents-e2e-dry/home"}
             :fixtures [[:remove "{root}"]
                        [:dir "{home}"]]}
    :cleanup {:fixtures [[:remove "{root}"]]}
    :when {:cwd "{work}"
           :env {"HOME" "{home}"}
           :run ["bb" "bootstrap" "all" "--dry-run"]}
    :then [[:exit-code 0]
           [:stdout-contains "Dry run: enabled"]
           [:stdout-contains "Would merge Claude settings"]
           [:stdout-contains "Would merge Pi settings"]
           [:fs-layout {:missing ["{home}/.claude"
                                  "{home}/.agents"
                                  "{home}/.pi"]}]]}]}

 {:suite :add-todo-helpers
  :desc "Add-todo helper script behavior"
  :given {:vars {:work "/work"
                  :fixtures-dir "test/fixtures"}}
  :cases
  [{:scenario :todo-new-adds-empty-labels-by-default
    :given {:vars {:root "/tmp/dotagents-e2e-todo-labels-default"}
             :fixtures [[:remove "{root}"]
                        [:dir "{root}"]]}
    :cleanup {:fixtures [[:remove "{root}"]]}
    :when {:cwd "{work}"
           :run ["bash" "{work}/shared/skills/add-todo/todo-new.sh"
                 "--type" "feature"
                 "--slug" "labels-default"
                 "--dir" "{root}/todos"]}
    :then [[:exit-code 0]
           [:stdout-contains "id=0001"]
           [:fs-layout {:contains [["{root}/todos/0001-labels-default.md" "labels: []"]]}]]}

   {:scenario :todo-new-writes-normalized-labels
    :given {:vars {:root "/tmp/dotagents-e2e-todo-labels-custom"}
             :fixtures [[:remove "{root}"]
                        [:dir "{root}"]]}
    :cleanup {:fixtures [[:remove "{root}"]]}
    :when {:cwd "{work}"
           :run ["bash" "{work}/shared/skills/add-todo/todo-new.sh"
                 "--type" "feature"
                 "--slug" "labels-custom"
                 "--labels" "MVP, NEXT_VER, MVP"
                 "--dir" "{root}/todos"]}
    :then [[:exit-code 0]
           [:stdout-contains "id=0001"]
           [:fs-layout {:contains [["{root}/todos/0001-labels-custom.md" "labels: [MVP, NEXT_VER]"]]}]]}

   {:scenario :todo-list-filters-by-label-and-ignores-missing-labels
    :given {:vars {:root "/tmp/dotagents-e2e-todo-label-filter"}
             :fixtures [[:remove "{root}"]
                        [:dir "{root}/todos"]
                        [:copy "{fixtures-dir}/todos/0001-labeled.md" "{root}/todos/0001-labeled.md"]
                        [:copy "{fixtures-dir}/todos/0002-no-labels.md" "{root}/todos/0002-no-labels.md"]]}
    :cleanup {:fixtures [[:remove "{root}"]]}
    :when {:cwd "{work}"
           :run ["bash" "{work}/shared/skills/add-todo/todo-list.sh"
                 "--label" "MVP"
                 "--dir" "{root}/todos"]}
    :then [[:exit-code 0]
           [:stdout-contains "0001"]
           [:stderr-contains "1 todo(s) found"]]}]}]
