[{:suite :bootstrap
  :desc "Bootstrap behavior through bb tasks in isolated temp homes"
  :given {:vars {:work "/work"
                  :fixtures-dir "test/fixtures"}}
  :cases
  [{:scenario :pi-writes-settings-for-extensions-themes-and-theme-name
    :given {:vars {:root "/tmp/dotagents-e2e-pi"
                   :home "/tmp/dotagents-e2e-pi/home"}
             :fixtures [[:remove "{root}"]
                        [:dir "{home}"]]}
    :cleanup {:fixtures [[:remove "{root}"]]}
    :when {:cwd "{work}"
           :env {"HOME" "{home}"}
           :run ["bb" "bootstrap" "pi"]}
    :then [[:exit-code 0]
           [:stdout-contains "== Pi =="]
           [:stdout-contains "Merging Pi settings"]
           [:fs-layout {:json-equals [["{home}/.pi/agent/settings.json" [:theme] "modus-operandi"]
                                      ["{home}/.pi/agent/settings.json" [:extensions] ["{work}/pi/extensions"]]
                                      ["{home}/.pi/agent/settings.json" [:themes] ["{work}/pi/themes"]]]
                        :missing ["{home}/.pi/agent/extensions"
                                  "{home}/.pi/agent/themes"
                                  "{home}/.pi/agent/justfile"]}]]}

   {:scenario :agents-copies-docs-and-links-helpers
    :given {:vars {:root "/tmp/dotagents-e2e-agents"
                   :home "/tmp/dotagents-e2e-agents/home"}
             :fixtures [[:remove "{root}"]
                        [:dir "{home}"]]}
    :cleanup {:fixtures [[:remove "{root}"]]}
    :when {:cwd "{work}"
           :env {"HOME" "{home}"}
           :run ["bb" "bootstrap" "agents"]}
    :then [[:exit-code 0]
           [:stdout-contains "== Agents =="]
           [:fs-layout {:symlinks [["{home}/.agents/AGENTS.md" "{work}/agents/AGENTS.md"]
                                   ["{home}/.codex/AGENTS.md" "{work}/agents/AGENTS.md"]
                                   ["{home}/.agents/skills/add-todo/src/todo/cli.clj" "{work}/shared/skills/add-todo/src/todo/cli.clj"]]
                        :regular-files ["{home}/.agents/skills/add-todo/SKILL.md"]}]]}

   {:scenario :claude-merges-settings
    :given {:vars {:root "/tmp/dotagents-e2e-claude"
                   :home "/tmp/dotagents-e2e-claude/home"}
             :fixtures [[:remove "{root}"]
                        [:dir "{home}/.claude"]
                        [:copy "{fixtures-dir}/claude-settings.json" "{home}/.claude/settings.json"]]}
    :cleanup {:fixtures [[:remove "{root}"]]}
    :when {:cwd "{work}"
           :env {"HOME" "{home}"}
           :run ["bb" "bootstrap" "claude"]}
    :then [[:exit-code 0]
           [:stdout-contains "== Claude =="]
           [:fs-layout {:json-equals [["{home}/.claude/settings.json" [:model] "keep-me"]
                                      ["{home}/.claude/settings.json" [:custom] {:nested true}]
                                      ["{home}/.claude/settings.json"
                                       [:hooks :PostToolUse 0 :hooks 0 :command]
                                       "{home}/.claude/hooks/smart-lint.sh"]]
                        :json-contains [["{home}/.claude/settings.json"
                                         [:permissions :allow]
                                         "Bash(/tmp/existing:*)"]
                                        ["{home}/.claude/settings.json"
                                         [:permissions :allow]
                                         "Bash(ag-tmux:*)"]]}]]}

   {:scenario :dry-run-makes-no-changes
    :given {:vars {:root "/tmp/dotagents-e2e-dry"
                   :home "/tmp/dotagents-e2e-dry/home"}
             :fixtures [[:remove "{root}"]
                        [:dir "{home}"]]}
    :cleanup {:fixtures [[:remove "{root}"]]}
    :when {:cwd "{work}"
           :env {"HOME" "{home}"}
           :run ["bb" "bootstrap" "all" "--dry-run"]}
    :then [[:exit-code 0]
           [:stdout-contains "Dry run: enabled"]
           [:stdout-contains "Would merge Claude settings"]
           [:stdout-contains "Would merge Pi settings"]
           [:fs-layout {:missing ["{home}/.claude"
                                  "{home}/.agents"
                                  "{home}/.pi"]}]]}]}

 {:suite :add-todo-bb
  :desc "Babashka todo CLI (replaces shell helpers)"
  :given {:vars {:work "/work"
                  :cli "{work}/shared/skills/add-todo/src"
                  :fixtures-dir "test/fixtures"}}
  :cases
  [{:scenario :bb-todo-new-creates-with-defaults
    :given {:vars {:root "/tmp/dotagents-e2e-bb-todo-new"}
             :fixtures [[:remove "{root}"]
                        [:dir "{root}"]]}
    :cleanup {:fixtures [[:remove "{root}"]]}
    :when {:cwd "{work}"
           :run ["bb" "-cp" "{cli}" "-m" "todo.cli"
                 "new" "--type" "feature" "--slug" "my-thing"
                 "--dir" "{root}/todos"]}
    :then [[:exit-code 0]
           [:stdout-contains "id=0001"]
           [:stdout-contains "filepath="]
           [:fs-layout {:contains [["{root}/todos/0001-my-thing.md" "labels: []"]]
                        :regular-files ["{root}/todos/0001-my-thing.md"]}]]}

   {:scenario :bb-todo-new-with-labels-and-parent
    :given {:vars {:root "/tmp/dotagents-e2e-bb-todo-parent"}
             :fixtures [[:remove "{root}"]
                        [:dir "{root}/todos"]
                        [:copy "{fixtures-dir}/todos/0001-labeled.md" "{root}/todos/0001-labeled.md"]]}
    :cleanup {:fixtures [[:remove "{root}"]]}
    :when {:cwd "{work}"
           :run ["bb" "-cp" "{cli}" "-m" "todo.cli"
                 "new" "--type" "chore" "--slug" "sub-thing"
                 "--labels" "MVP,BETA" "--parent" "0001"
                 "--dir" "{root}/todos"]}
    :then [[:exit-code 0]
           [:stdout-contains "id=0001.1"]
           [:fs-layout {:contains [["{root}/todos/0001.1-sub-thing.md" "labels: [MVP, BETA]"]
                                   ["{root}/todos/0001.1-sub-thing.md" "parent: 0001"]]}]]}

   {:scenario :bb-todo-list-filters-by-label
    :given {:vars {:root "/tmp/dotagents-e2e-bb-todo-list"}
             :fixtures [[:remove "{root}"]
                        [:dir "{root}/todos"]
                        [:copy "{fixtures-dir}/todos/0001-labeled.md" "{root}/todos/0001-labeled.md"]
                        [:copy "{fixtures-dir}/todos/0002-no-labels.md" "{root}/todos/0002-no-labels.md"]]}
    :cleanup {:fixtures [[:remove "{root}"]]}
    :when {:cwd "{work}"
           :run ["bb" "-cp" "{cli}" "-m" "todo.cli"
                 "list" "--label" "MVP"
                 "--dir" "{root}/todos"]}
    :then [[:exit-code 0]
           [:stdout-contains "0001"]
           [:stderr-contains "1 todo(s) found"]]}

   {:scenario :bb-todo-status-updates-frontmatter
    :given {:vars {:root "/tmp/dotagents-e2e-bb-todo-status"}
             :fixtures [[:remove "{root}"]
                        [:dir "{root}/todos"]
                        [:copy "{fixtures-dir}/todos/0001-labeled.md" "{root}/todos/0001-labeled.md"]]}
    :cleanup {:fixtures [[:remove "{root}"]]}
    :when {:cwd "{work}"
           :run ["bb" "-cp" "{cli}" "-m" "todo.cli"
                 "status" "0001" "closed"
                 "--dir" "{root}/todos"]}
    :then [[:exit-code 0]
           [:stdout-contains "old_status=open"]
           [:stdout-contains "new_status=closed"]
           [:fs-layout {:contains [["{root}/todos/0001-labeled.md" "status: closed"]]}]]}

   {:scenario :bb-todo-next-id-increments
    :given {:vars {:root "/tmp/dotagents-e2e-bb-todo-nextid"}
             :fixtures [[:remove "{root}"]
                        [:dir "{root}/todos"]
                        [:copy "{fixtures-dir}/todos/0001-labeled.md" "{root}/todos/0001-labeled.md"]
                        [:copy "{fixtures-dir}/todos/0002-no-labels.md" "{root}/todos/0002-no-labels.md"]]}
    :cleanup {:fixtures [[:remove "{root}"]]}
    :when {:cwd "{work}"
           :run ["bb" "-cp" "{cli}" "-m" "todo.cli"
                 "next-id" "--dir" "{root}/todos"]}
    :then [[:exit-code 0]
           [:stdout-contains "0003"]]}]}

 {:suite :tmux-agent-bb
  :desc "Babashka tmux-agent CLI"
  :given {:vars {:work "/work"
                  :cli "{work}/shared/skills/pk-tmux/src"}}
  :cases
  [{:scenario :bb-tmux-create-and-run
    :when {:cwd "{work}"
           :run ["bash" "-c"
                 "bb -m tmux-agent.cli create e2e-tmux /tmp && bb -m tmux-agent.cli run test-win 'echo hello-e2e' --sock /tmp/agents-e2e-tmux.sock --session e2e-tmux --timeout 10; rc=$?; tmux -S /tmp/agents-e2e-tmux.sock kill-server 2>/dev/null; exit $rc"]}
    :then [[:exit-code 0]
           [:stdout-contains "hello-e2e"]]}

   {:scenario :bb-tmux-create-is-idempotent
    :when {:cwd "{work}"
           :run ["bash" "-c"
                 "bb -m tmux-agent.cli create e2e-idem /tmp && bb -m tmux-agent.cli create e2e-idem /tmp; rc=$?; tmux -S /tmp/agents-e2e-idem.sock kill-server 2>/dev/null; exit $rc"]}
    :then [[:exit-code 0]
           [:stdout-contains "Session already exists"]]}]}]
